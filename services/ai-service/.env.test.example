# Test environment overrides
# Copy to .env.test (or export inline) before running pytest.
# DO NOT put real production credentials here.

# Local test database (any throwaway Postgres works)
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/test_db

# Optional: provide if you want tests that hit the actual LLM to run.
# Leave empty to skip those tests.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
