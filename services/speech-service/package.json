{
  "name": "speech-service",
  "version": "1.0.0",
  "description": "Complete Speech Service: TTS, ASR, and Pronunciation Assessment",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "speech",
    "tts",
    "asr",
    "pronunciation",
    "text-to-speech",
    "speech-recognition",
    "openai",
    "azure",
    "google"
  ],
  "author": "LittleGrape Team",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google-cloud/text-to-speech": "^5.0.0",
    "@littlegrape/shared": "workspace:*",
    "axios": "^1.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "find-up": "^7.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.46.0",
    "mime-types": "^2.1.35",
    "multer": "^2.0.0",
    "openai": "^4.20.1",
    "protobufjs": "^8.0.1",
    "redis": "^4.6.10",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/fluent-ffmpeg": "^2",
    "@types/jest": "^29.5.8",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.5",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
