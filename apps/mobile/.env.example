# LittleGrape Mobile — environment template
# Copy this file to `.env` in `apps/mobile/` and fill in real values.
# These values are read at build time via expo-constants / process.env.
#
# 复制此文件为 .env 并填写实际值。

# =================
# 前端 API 配置 (Frontend API)
# 移动端连接的 API Gateway 地址
# 本地调试时改成你的局域网 IP, 如 http://192.168.x.x:3000
# =================
API_GATEWAY_URL=https://your-api-domain.com

# =================
# 微信开放平台 (WeChat — mobile-side)
# 与根目录 .env 中 WECHAT_APP_ID 保持一致
# =================
WECHAT_APP_ID=your_wechat_app_id

# =================
# 阿里云号码认证 PNVS (一键登录)
# 控制台「方案管理」→「密钥」获取
# 三个 secret 分别对应 iOS / Android release / Android debug 三套签名
# =================
# iOS 业务密钥
PNVS_AUTH_SECRET_IOS=your_pnvs_auth_secret_for_ios
# Android Release 签名
PNVS_AUTH_SECRET_ANDROID=your_pnvs_auth_secret_for_android_release
# Android Debug 签名 (开发期使用)
PNVS_AUTH_SECRET_ANDROID_DEBUG=your_pnvs_auth_secret_for_android_debug
