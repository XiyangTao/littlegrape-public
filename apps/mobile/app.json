{
  "expo": {
    "name": "小葡萄",
    "slug": "littlegrape",
    "version": "1.1.5",
    "scheme": [
      "littlegrape",
      "wx3a4de98233549d14"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cn.coderhythm.littlegrape",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "cn.coderhythm.littlegrape",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-custom-assets",
        {
          "assetsPaths": [
            "./assets/sqlite"
          ],
          "preserveFolder": true
        }
      ],
      "expo-audio",
      "expo-native-wechat",
      "./modules/aliyun-pnvs/plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "<your-eas-project-id>"
      }
    }
  }
}