# LittleGrape — Root environment template
# Copy this file to `.env` at repo root and fill in real values.
# This file is loaded by api-gateway, speech-service, and ai-service.
#
# 复制此文件为 .env 并填写实际值。
# `.env` 文件被 api-gateway / speech-service / ai-service 共享读取。

# =================
# 邮件 / SMTP (Email)
# =================
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password_here

EMAIL_FROM_NAME=LittleGrape
EMAIL_FROM_ADDRESS=your_smtp_user@example.com

# =================
# 阿里云通用凭证 (Aliyun core credentials)
# 一个 AK 对常被 OSS / SMS / 短信复用
# =================
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# =================
# 阿里云短信 (Aliyun SMS)
# 在阿里云短信控制台「签名管理」「模板管理」获取
# =================
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_LOGIN=SMS_xxxxxxxxx
ALIYUN_SMS_TEMPLATE_PASSWORD_RESET=SMS_xxxxxxxxx
ALIYUN_SMS_TEMPLATE_BIND_PHONE=SMS_xxxxxxxxx

# =================
# 阿里云 OSS + CDN (Object Storage)
# =================
ALIYUN_OSS_REGION=oss-cn-beijing
ALIYUN_OSS_BUCKET_NAME=your_oss_bucket_name
ALIYUN_OSS_CDN_DOMAIN=https://cdn.yourdomain.com

# =================
# PostgreSQL
# =================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=littlegrape
POSTGRES_USER=littlegrape_admin
POSTGRES_PASSWORD=change_me_to_strong_db_password
# Prisma 使用的 URL — 注意密码与上方保持一致
POSTGRES_DATABASE_URL="postgresql://littlegrape_admin:change_me_to_strong_db_password@localhost:5432/littlegrape"

# =================
# Redis
# =================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_to_strong_redis_password
REDIS_DB=0

# =================
# JWT 认证 (生成: openssl rand -hex 32)
# =================
JWT_SECRET=change_me_run_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_run_openssl_rand_hex_32_different_from_above
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =================
# LLM Providers
# =================

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 豆包 / 火山方舟 (Volcengine Ark)
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Anthropic (optional — uncomment if needed)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Generative AI (optional)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_genai_api_key_here

# DashScope / 阿里云百炼 — Embedding
DASHSCOPE_API_KEY=sk-your_dashscope_api_key_here

# =================
# 讯飞语音 (iFlytek)
# 控制台「我的应用」获取
# =================
XUNFEI_APP_ID=your_xunfei_app_id
XUNFEI_API_KEY=your_xunfei_api_key
XUNFEI_API_SECRET=your_xunfei_api_secret

# =================
# Azure Speech (TTS + ASR) + Translator
# =================
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_KEY=your_azure_translator_key_here
AZURE_TRANSLATOR_REGION=eastus

# =================
# 豆包 TTS 2.0 (Volcengine Voice)
# =================
DOUBAO_TTS_APP_ID=your_doubao_tts_app_id
DOUBAO_TTS_ACCESS_TOKEN=your_doubao_tts_access_token
DOUBAO_TTS_CLUSTER=volcano_tts

# =================
# 火山引擎同声传译 (Volcano Simultaneous Translation)
# =================
VOLCANO_AST_APP_KEY=your_volcano_ast_app_key
VOLCANO_AST_ACCESS_KEY=your_volcano_ast_access_key

# =================
# 运行时 (Runtime)
# =================
LOG_LEVEL=info
RUNTIME_ENV=development
# 生产环境记得改为具体域名: https://yourdomain.com
CORS_ORIGIN=*
CORS_CREDENTIALS=true
REQUEST_BODY_LIMIT=10mb

# =================
# 服务端口 (Service Ports)
# =================
API_GATEWAY_PORT=3000
AI_SERVICE_PORT=3001
SPEECH_SERVICE_PORT=3003

# =================
# 微信开放平台 (WeChat Login)
# 开放平台「应用详情」获取
# =================
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# =================
# 支付宝 (Alipay)
# 蚂蚁开放平台获取
# =================
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_APP_PRIVATE_KEY=your_alipay_app_rsa_private_key_here
ALIPAY_PUBLIC_KEY=your_alipay_public_key_here
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-api-domain.com/api/order/alipay/notify

# =================
# Admin API (内部管理接口鉴权 token)
# =================
ADMIN_API_KEY=change_me_to_strong_random_admin_key
