// 帖子点赞表
model UserPostLike {
  id         String   @id @default(cuid())
  postId     String
  userId     String

  createdAt  DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@map("user_post_likes")
}

// ==================== AI 学习助手模块 ====================

// 助手记忆表 - 存储用户画像快照，作为 AI system prompt 数据源
model AssistantMemory {
  id             String   @id @default(cuid())
  userId         String   @unique
  userProfile    Json     // {nickname, gender, birthday, bio, level, xp}
  learningStats  Json     // {totalLearned, totalMastered, streakDays, ...}
  recentProgress Json     // {last7DaysLearned, weakWords, todayLearned, ...}
  preferences    Json     // {studyGoals, topics, ...}
  aiInsights     Json?    // AI 提取的用户洞察
  lastSnapshotAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_assistant_memories")
}

// 助手消息表 - 服务端持久化对话历史
model AssistantMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'user' | 'assistant'
  content   String   @db.Text
  metadata  Json?    // {quickAction?, pushSource?, voiceUri?}
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("user_assistant_messages")
}

// 系统通知表 - 记录推送通知，防重复 + 效果分析
model UserNotification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // 通知类型: daily_remind, birthday, weekly_summary...
  channel     String    // 'in_app' | 'notification'
  content     String    // 通知内容
  triggerData Json?     // 触发数据快照
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@index([userId, type, createdAt])
  @@map("user_notifications")
}

// ==================== 用户反馈模块 ====================

// 用户反馈表
model UserFeedback {
  id        String   @id @default(cuid())
  userId    String   // 用户ID
  type      String   // 反馈类型：bug(问题反馈) / feature(功能建议) / other(其他)
  content   String   @db.Text // 反馈内容
  images    Json?    // 图片URL数组，最多5张 ["https://...", "https://..."]
  status    String   @default("pending") // 状态：pending(待处理) / processing(处理中) / resolved(已解决) / closed(已关闭)

  // 用户设备信息（可选）
  deviceInfo String? // 设备信息 JSON，包含系统版本、App版本等

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("user_feedbacks")
}

// ==================== 每日挑战赛 ====================

model DailyChallenge {
  id            String   @id @default(cuid())
  date          String   @unique  // YYYY-MM-DD
  questions     Json               // [{wordId, word, meaningCn, type, options, correctIndex}]
  totalQuestions Int      @default(20)
  timeLimit     Int      @default(300) // 秒
  createdAt     DateTime @default(now())

  @@map("daily_challenges")
}

model DailyChallengeResult {
  id            String   @id @default(cuid())
  userId        String
  date          String
  score         Int
  correctCount  Int
  totalQuestions Int
  maxCombo      Int      @default(0)
  duration      Int               // 实际用时（秒）
  createdAt     DateTime @default(now())

  @@unique([userId, date])
  @@index([date, score])
  @@index([userId])
  @@map("user_daily_challenge_results")
}

// ==================== 成就系统增强 ====================

// 成就事件日志表（支撑时间窗口/连续天数条件查询）
model AchievementEventLog {
  id         String   @id @default(cuid())
  userId     String
  eventType  String
  metadata   Json?                  // 事件上下文数据
  eventDate  String                 // YYYY-MM-DD (Asia/Shanghai)
  createdAt  DateTime @default(now())

  @@index([userId, eventType, createdAt])
  @@index([userId, eventDate])
  @@map("user_achievement_event_logs")
}

// 赛季定义表
model Season {
  id          String   @id @default(cuid())
  code        String   @unique       // 'S1_2026Q1', 'S2_2026Q2'
  nameZh      String
  nameEn      String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  theme       String?                // 赛季主题
  rewards     Json?                  // 赛季结算奖励配置
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([startDate, endDate])
  @@map("seasons")
}

// ==================== 每日/每周任务系统 ====================

// 任务模板定义表（运营配置）
model TaskTemplate {
  id            String   @id @default(cuid())
  code          String   @unique     // 'learn_10_words', 'review_20_words'
  type          String               // 'daily' | 'weekly'
  nameZh        String
  nameEn        String
  descriptionZh String
  descriptionEn String
  icon          String
  condition     Json                 // 任务条件 JSON
  xpReward      Int      @default(10)
  weight        Int      @default(100) // 随机选取权重
  minLevel      Int      @default(1)   // 最低等级要求
  maxLevel      Int      @default(30)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type, isActive])
  @@map("task_templates")
}

// 用户每日任务实例表
model UserDailyTask {
  id            String    @id @default(cuid())
  userId        String
  templateCode  String               // 关联 TaskTemplate.code
  taskDate      String               // YYYY-MM-DD
  type          String               // 'daily' | 'weekly'
  nameZh        String               // 快照
  nameEn        String
  icon          String
  targetValue   Int                  // 目标值
  xpReward      Int
  currentValue  Int       @default(0)
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  isClaimed     Boolean   @default(false)
  claimedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, templateCode, taskDate])
  @@index([userId, taskDate])
  @@index([userId, type, taskDate])
  @@map("user_daily_tasks")
}

// 每日任务全部完成奖励表
model UserDailyTaskBonus {
  id         String   @id @default(cuid())
  userId     String
  taskDate   String               // YYYY-MM-DD
  xpAwarded  Int
  claimedAt  DateTime @default(now())

  @@unique([userId, taskDate])
  @@map("user_daily_task_bonus")
}

// ==================== 社交展示系统 ====================

// 徽章展柜（用户精选展示）
model UserBadgeShowcase {
  id            String   @id @default(cuid())
  userId        String
  achievementId String               // 成就 code
  slotIndex     Int                  // 展位序号 0-4

  createdAt     DateTime @default(now())

  @@unique([userId, slotIndex])
  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_badge_showcases")
}

// 成就分享记录
model AchievementShare {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  shareType     String               // 'image' | 'link'
  shareUrl      String?
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("user_achievement_shares")
}

// ==================== 语法学习模块 ====================

// 语法学习单元表（Duolingo 风格等级-单元制，5 个等级 × 18 个单元）
model GrammarCategory {
  id          String   @id @default(cuid())
  code        String   @unique              // 'nouns', 'talking_about_time', ...
  nameZh      String                        // 中文名称
  nameEn      String                        // 英文名称
  icon        String                        // 图标名称
  color       String   @default("#7C5CFC")  // 单元颜色
  description String?                       // 单元描述
  level       Int      @default(1)          // 所属等级 1-5
  sortOrder   Int      @default(0)          // 等级内排序

  points      GrammarPoint[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([level])
  @@map("grammar_categories")
}

// 语法点表（约80个）
model GrammarPoint {
  id            String   @id @default(cuid())
  categoryId    String
  category      GrammarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  code          String   @unique             // 'simple_present', 'past_continuous', ...
  nameZh        String                       // "一般现在时"
  nameEn        String                       // "Simple Present Tense"
  difficulty    String   @default("basic")   // 'basic' | 'intermediate' | 'advanced'
  sortOrder     Int      @default(0)

  // AI 生成的讲解内容（缓存）
  explanation   String?  @db.Text            // AI 生成的 Markdown 讲解
  examples      Json?                        // [{en: "...", zh: "...", highlight: "..."}]
  explanationGeneratedAt DateTime?           // 讲解生成时间

  practices     GrammarPractice[]
  userProgress  UserGrammarProgress[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
  @@index([difficulty])
  @@map("grammar_points")
}

// 语法练习题表（AI 生成后缓存）
// type: 'choice' | 'fill_blank' | 'error_judgment' | 'error_correction' | 'dual_blank' | 'sentence_reorder' | 'word_assembly' | 'table_fill'
// cognitiveLevel: 'recognition'(识别) | 'understanding'(理解) | 'production'(产出)
model GrammarPractice {
  id            String   @id @default(cuid())
  pointId       String
  point         GrammarPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  type          String                       // 题型
  cognitiveLevel String  @default("recognition") // 认知层级
  question      String                       // 题干
  options       Json?                        // 选项数组
  answer        String                       // 正确答案
  explanation   String?                      // 解析
  difficulty    String   @default("basic")   // 与语法点难度一致

  // 新题型扩展字段
  smartTip      Json?                        // Smart Tip: { rule, wrong, correct, examples }
  errorPart     String?                      // 纠错题：错误部分文本
  correctVersion String?                     // 纠错题：完整正确句子
  sentence1     String?                      // 双空对比题：句子1
  sentence2     String?                      // 双空对比题：句子2
  answer2       String?                      // 双空对比题：句子2的答案
  tableData     Json?                        // 填表题：表格数据 { headers, rows, blanks }
  words         Json?                        // 重组/选词组句：单词列表
  distractors   Json?                        // 选词组句：干扰词列表
  chineseTranslation String?                 // 重组/选词组句：中文翻译
  structureHint String?                      // 重组题：结构提示
  acceptableAnswers Json?                    // 可接受的多个答案

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pointId])
  @@index([pointId, type])
  @@index([pointId, cognitiveLevel])
  @@map("grammar_practices")
}

// 用户语法学习进度表
model UserGrammarProgress {
  id              String    @id @default(cuid())
  userId          String
  pointId         String
  point           GrammarPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  status          String    @default("not_started")   // 'not_started' | 'learning' | 'practiced' | 'mastered'
  readAt          DateTime?                            // 阅读讲解的时间
  practiceScore   Int?                                 // 最近一次练习得分 (0-100)
  practiceCount   Int       @default(0)                // 练习次数
  bestScore       Int?                                 // 历史最高分
  starRating      Int?                                 // 最近一次星级 (1-5)
  bestStarRating  Int?                                 // 历史最高星级 (1-5)
  lastPracticedAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, pointId])
  @@index([userId])
  @@index([userId, status])
  @@map("user_grammar_progress")
}

// 用户音素练习进度表
model UserPhonemeProgress {
  id                 String    @id @default(cuid())
  userId             String
  phonemeSymbol      String    // IPA 音素符号，如 /ɪ/
  practiceCount      Int       @default(0)
  totalWordCount     Int       @default(0)
  avgScore           Float     @default(0)
  bestScore          Float     @default(0)
  lastScore          Float     @default(0)
  masteryLevel       String    @default("none") // none|beginner|intermediate|advanced|mastered
  listenCorrectCount Int       @default(0)
  listenTotalCount   Int       @default(0)
  lastPracticedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([userId, phonemeSymbol])
  @@index([userId])
  @@index([userId, updatedAt])
  @@map("user_phoneme_progress")
}

// 用户关注关系表（单向关注）
model UserFollow {
  id          String   @id @default(cuid())
  followerId  String   // 关注者（主动方）
  followingId String   // 被关注者（被动方）
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

// ==================== AI 伙伴对话模块 ====================

// Mem0 伙伴对话消息记录 — 服务端日志，前端不读取
model CompanionMem0Message {
  id          String   @id @default(cuid())
  userId      String
  characterId String   // "mia", "alex" 等
  sessionId   String   // 会话标识，同一次对话共享
  role        String   // "user" | "assistant"
  content     String   @db.Text
  createdAt   DateTime @default(now())

  @@index([userId, characterId, createdAt])
  @@index([sessionId])
  @@map("user_companion_mem0_messages")
}

