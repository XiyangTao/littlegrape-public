  userId             String   @unique
  totalLearned       Int      @default(0)
  totalMastered      Int      @default(0)
  totalReviewed      Int      @default(0)
  totalConversations Int      @default(0)
  totalListening     Int      @default(0)
  totalReading       Int      @default(0)
  totalDiaries       Int      @default(0)
  totalLevels          Int      @default(0)
  totalBossKills       Int      @default(0)
  totalPerfectStars    Int      @default(0)
  totalSentences       Int      @default(0)
  totalDailyChallenges Int      @default(0)
  totalSpeedReviews    Int      @default(0)
  totalRootsLit        Int      @default(0)
  totalEncounters      Int      @default(0)
  totalDailyTaskDays   Int      @default(0)  // 每日任务全部完成的天数
  totalPhonemePractices Int    @default(0)
  streakDays         Int      @default(0)
  maxStreakDays      Int      @default(0)
  lastActiveDate     String?
  dailyXpEarned      Int      @default(0)
  dailyXpDate        String?
