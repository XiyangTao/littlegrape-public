// 成就定义表（替代硬编码 ACHIEVEMENTS 数组）
model AchievementDefinition {
  id             String   @id @default(cuid())
  code           String   @unique          // 唯一标识: 'first_word', 'words_50'...
  seriesCode     String?                   // 阶梯系列: 'words_series', 'streak_series'
  tier           Int      @default(1)      // 阶梯等级: 1,2,3,4...
  nameZh         String
  nameEn         String
  descriptionZh  String
  descriptionEn  String
  icon           String
  category       String                    // learning | streak | practice | milestone
  xpReward       Int      @default(0)
  ruleType       String   @default("stat") // stat | level
  conditions     Json?                     // ConditionNode JSON（向后兼容旧格式 [{stat,op,value}]）
  triggerEvents  Json?                     // ['word_learned', ...]
  levelCondition Int?                      // 等级成就的等级阈值
  isHidden       Boolean  @default(false)  // 隐藏成就
  rarity         String?                   // common | rare | epic | legendary
  rarityPercent  Float?                    // X% 用户已解锁
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  // 赛季/限时支持
  seasonCode     String?                   // 关联 Season.code（null=永久成就）
  availableFrom  DateTime?                 // 限时成就开始时间
  availableUntil DateTime?                 // 限时成就结束时间
  isLimited      Boolean  @default(false)  // 是否限时
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([category])
  @@index([seriesCode, tier])
  @@index([seasonCode])
  @@map("achievement_definitions")
